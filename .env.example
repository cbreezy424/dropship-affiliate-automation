# Flask Configuration
FLASK_ENV=development
FLASK_SECRET_KEY=your-secret-key-here-change-in-production
FLASK_DEBUG=True

# API Keys
GROQ_API_KEY=your_groq_api_key_here

# Affiliate Configuration
AMAZON_AFFILIATE_ID=your_amazon_affiliate_id
AMAZON_REGION=com

# Database
DATABASE_URL=sqlite:///dropship.db

# Video Settings
VIDEO_FRAME_RATE=30
VIDEO_QUALITY=720p
VIDEO_DURATION=30
VOICE_LANGUAGE=en

# Paths
UPLOAD_FOLDER=uploads
VIDEO_OUTPUT_FOLDER=videos
TEMP_FOLDER=temp
